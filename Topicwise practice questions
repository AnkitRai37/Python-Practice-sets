def recursive_factorial(n):
    if n == 0 or n == 1:
        return 1
    return n * recursive_factorial(n-1)
print(recursive_factorial(5))

Q-22,
def recursive_fibonacci(n):
    if n <= 1:
        return n
    return recursive_fibonacci(n-1) + recursive_fibonacci(n-2)
print(recursive_fibonacci(8))

